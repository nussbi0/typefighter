{
  "name": "typefighter",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck:worker": "tsc -p worker/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:api": "wrangler dev",
    "db:migrate:local": "wrangler d1 migrations apply typefighter --local",
    "db:migrate": "wrangler d1 migrations apply typefighter --remote",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260603.1",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.4.0",
    "vitest": "^2.1.9",
    "wrangler": "^4.40.0"
  }
}
