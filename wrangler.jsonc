{
  "name": "typefighter",
  "main": "worker/index.ts",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  // Run `wrangler d1 create typefighter` and paste the returned database_id below.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "typefighter",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID",
    },
  ],
}
