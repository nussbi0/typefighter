{
  "name": "typefighter",
  "main": "worker/index.ts",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  // D1 binding for the leaderboard. The database_id is an account-scoped
  // identifier (not a secret); created via `wrangler d1 create typefighter`.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "typefighter",
      "database_id": "97454df0-d15d-40b0-aa4b-7214646b58b6",
    },
  ],
}
